t\t\t<option value='&#x7121;'>&#x7121;</option>\n\t\t</select></td><td style='width:30%;'></td></tr><tr><td colspan='2'><div class='dIB vat mT2' align='left' style='vertical-align: top;'><div class='displayPurpose  f13'><label class='newCustomchkbox-md dIB w100per'><input autocomplete='off' onclick='disableSubmit()' id='privacyTool' type='checkbox' name='privacyTool'><span class='chkbxIcon'></span></label></div></div><div class='fw200 dIB vat mL5' style='nowrap:nowrap;text-align:left;color:white;vertical-align: top;margin-top: 3px;line-height: 14px;width:90%;display: inline-block;color:#fff'><div><font face='Verdana, Arial, Helvetica, sans-serif'><span style='font-size: 14px;'>下記3点を確認の上、同意します。</span></font></div><ul style='padding-left:20px;margin-top: 0;' style='padding-left:20px;margin-top: 0;'><li>当社の把握する限り、反社会的勢力との関係はないことを確認しました。</li><li><a href='https://design-ship.jp/codeofconduct' target='_blank' rel='noopener noreferrer' data-mce-href='https://design-ship.jp/codeofconduct'>行動規範</a></li><li><a href='https://design-ship.jp/privacypolicy' target='_blank' rel='noopener noreferrer' data-mce-href='https://design-ship.jp/privacypolicy'>プライバシーポリシー</a></li><li>協賛に関してのポリシー</li></ul></div>\n\n\t<tr><td colspan='2' style='text-align:center; padding-top:15px;'>\n\t\t<input style='opacity:0.5;margin-right: 5px;cursor: pointer;color:#fff' id='formsubmit'disabled type='submit' value='送信'  ></input> </td></tr></table>\n\t<script>\n \t  var mndFileds=new Array('Last Name','First Name','Email','Phone','LEADCF2','Zip Code','State','City','Street','Website','LEADCF4','Company','theFile');\n \t  var fldLangVal=new Array('ご担当者名（姓）','ご担当者名（名）','メールアドレス（担当者）','電話番号','部署名','郵便番号','都道府県','市区町村','町名・番地','Webサイト','請求書原本送付','会社名',); \n\t\tvar name='';\n\t\tvar email=''; \n  \nfunction disableSubmitwhileReset()\n\t{\t\t\n\tvar submitbutton = document.getElementById('formsubmit');\n   var style = submitbutton.getAttribute('style');\n   if (style.indexOf('opacity:0.5')<0) {\n   style='opaci