type":"text"},"name":"Text","style":{"@mini":{"fontSize":"24px"},"@mobile":{"fontSize":"24px"},"color":"#FFFFFF","flex":"none","fontFamily":"var(--s-font-b480a875)","fontSize":"32px","fontWeight":700,"height":"auto","letterSpacing":"0.06em","lineHeight":"1.4","margin":"0px 0px 0px 0px","textAlign":"left","width":"100%"},"tagName":"","uuid":"fcc39774-a3e8-4901-9d78-4393dacf57dc","children":[]},{"content":{"data":"Day1 10/12(Sat.) 13:00-14:30","type":"text"},"name":"Text","style":{"@mobile":{"fontSize":"16px"},"color":"#FFFFFF","flex":"none","fontFamily":"var(--s-font-b480a875)","fontSize":"20px","fontWeight":"700","height":"auto","letterSpacing":"0.06em","lineHeight":"normal","margin":"0px 0px 0px 0px","textAlign":"left","width":"auto"},"tagName":"","uuid":"cf675250-b539-46b7-bd6b-cb20618e41b5","children":[]}],"name":"<group>","style":{"alignContent":"flex-start","alignItems":"flex-start","flexDirection":"column","flexWrap":"nowrap","gap":"12px","justifyContent":"center","padding":"0px"},"tagName":"div","uuid":"0e658b8e-6988-4a02-8fc1-e2e569acd0b3"},{"content":{"data":"▼概要<br>『自分の意思が伝わるドキュメントとは何か、メドレーの「ドキュメントドリブン」を体験してみよう』<br>「医療ヘルスケアの未来をつくる」メドレーではOur Essentialsという行動原則の中で「ドキュメントドリブン」という概念を掲げています。ドキュメントドリブンとは企画の意図や計画をドキュメントとして言語化し、そのドキュメントを起点にチームと協働し仕事が進む”装置”としてドキュメントを書くことを大切にしています。<br>本ワークショップではみなさんの日々の実践に活かしてもらえるよう、レクチャーとワークを通じてメドレー流のドキュメントドリブンを意識したドキュメンテーション能力が身に着く内容となっています。仕事の進め方やビジネススキルを身につけることに関心がある方にオススメです。<br><br>▼場所<br>Workshop Area @5F リエゾンセンター<br><br>▼参加方法<br>事前の参加申込が必要です。<br>「チケット購入」ボタンより「コンテンツチケット - Workshop（10/12）」へのお申し込みをお願いします。<br><br>▼当日に関するご案内<br>・PCもしくはタブレットを使ったグループワークを行う予定です。OS/スペックは問いませんので、ご自身のPCもしくはタブレットをご持参ください。<br>・ワークでは、ご自身のGoogleアカウントにログインいただき、Googleサービスも利用する予定です。<br>","type":"text"},"name":"Text","style":{"@mobile":{"fontSize":"12px"},"color":"#FFFFFF","flex":"none","fontFamily":"var(--s-font-b480a875)","fontSize":"14px","fontWeight":700,"height":"auto","letterSpacing":"0.06em","lineHeight":"2","margin":"0px 0px 0px 0px","textAlign":"left","