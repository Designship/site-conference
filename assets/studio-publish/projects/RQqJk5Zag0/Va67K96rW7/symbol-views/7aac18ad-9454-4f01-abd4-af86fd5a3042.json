":"d309aa4d-66ad-4f9d-b29f-f6199c5369dc","children":[]}],"name":"<group>","renderIf":"boolean1.value","style":{"@mini":{"display":"flex"},"@mobile":{"display":"flex","flex":"none","padding":"16px 24px"},"@small":{"display":"flex"},"@tablet":{"display":"flex","flex":"none","width":"100%"},"alignContent":"flex-start","alignItems":"flex-start","background":"#2d3040ff","display":"flex","flex":"none","flexDirection":"column","flexWrap":"nowrap","justifyContent":"flex-start","padding":"32px","width":"100%"},"tagName":"div","uuid":"e5c5216e-739d-4acb-a6d5-39370964c2c8"}],"defs":[{"key":"image2","name":"Thumbnail","type":"image","uid":"AVPaGEzX"},{"key":"text6","name":"Name","type":"string","uid":"2DsnO9b3"},{"key":"text4","name":"Type","type":"string","uid":"41ObuTdr"},{"key":"text5","name":"Title","type":"string","uid":"AIPnsLVy"},{"key":"text7","name":"Explanation","type":"string","uid":"LOUwMhZO"},{"key":"boolean1","name":"showSessionInfo","type":"boolean","uid":"ZvYDGcUE"},{"key":"text9","name":"SessionTitle","type":"string","uid":"RoBtmHOc"},{"key":"text10","name":"SessionDetail","type":"string","uid":"0KEFhfko"},{"key":"boolean2","name":"hasURL","type":"boolean","uid":"DhnRNB4J"},{"key":"url1","name":"URL","type":"url","uid":"7JPLTBXy"},{"key":"boolean3","name":"hasMainStage","type":"boolean","uid":"fvFSf0yT"},{"key":"boolean4","name":"hasOpenStage","type":"boolean","uid":"KlH3zx3A"}],"id":"","name":"<group>","state":{"boolean1":false,"boolean2":false,"boolean3":false,"boolean4":false,"image2":"/assets/studio-design-asset-files/projects/RQqJk5Zag0/s-600x600_v-fs_webp_e3a69c36-69c1-4382-9359-2680220aec1e.jpg","text1":"Hello World.","text10":"自由なデザインなどあり得ません。デザインには必ず制約があるからです。しかも俳句のように不自由にすることによって、無限のアイデアが生まれたりします。それでは、デザイナーの自由な生き方というのはあり得るのでしょうか。この度のスピーチでは、デザインにおける自由不自由、そしてデザイナーのスタイル、さらには個性について想うところをお話してみたいと思います。","text4":"Keynote","text5":"グラフィックデザイナー","text6":"佐藤 卓","text7":"1979年東京藝術大学デザイン科卒業、81年同大学院修了。株式会社電通を経て、84年独立。株式会社TSDO代表。公益社団法人日本グラフィックデザイン協会（JAGDA）会長。「ロッテ キシリトールガム」「明治おいしい牛乳」のパッケージデザイン、ポスターのグラフィック、商品や施設のブランディング、企業のCIを中心に活動。NHK Eテレ「デザインあ」「デザインあneo」総合指導、21_21 DESIGN SIGHT館長を務め、展覧会も多数企画・開催。著書に『塑する思考』（新潮社）、『マークの本』（紀伊國屋書店）、『Just Enough Design』（Chronicle Books）など。毎日デザイン賞、芸術選奨文部科学大臣賞、紫綬褒章他受賞。","text9":"デザインの自由不自由","url1":""},"style":{"@mini":{"display":"flex"},"@mobile":{"alignContent":"flex-start","alignItems":"flex-start","display":"flex","flex":"none","justifyContent":"center","width":"92%"},"@small":{"display":"flex"},"@tablet":{"display":"flex","flex":"none","width":"720px"},"alignContent":"center","alignItems":"center","display":"flex","flex":"none","flexWrap":"nowrap","justifyContent":"center","margin":"0px 0px 0px 0px","padding":"0px","width":"820px"},"tagName":"div","type":"component","uuid":"c2d0cac7-5ab6-4bc7-8b62-00af3dafbf80"}